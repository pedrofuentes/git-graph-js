{
  "name": "git-graph-js",
  "version": "0.1.0",
  "description": "Command line tool to show clear git graphs arranged for your branching model. TypeScript port of git-graph v0.7.0 by Martin Lange.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "git-graph-js": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "git",
    "graph",
    "cli",
    "terminal",
    "visualization"
  ],
  "author": "Pedro Fuentes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pedrofuentes/git-graph-js.git"
  },
  "homepage": "https://github.com/pedrofuentes/git-graph-js",
  "type": "commonjs",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "env-paths": "^4.0.0",
    "isomorphic-git": "^1.37.4",
    "smol-toml": "^1.6.1",
    "wrap-ansi": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "subset-font": "^2.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
